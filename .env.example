# the-agent-that-got-me-rejected environment configuration.
# Copy to `.env` and fill in. The app runs with NO keys at all (Remotive +
# cached dataset), but you get the full lesson (real cost, live jobs, tracing)
# with the three services below.
#
# NOTE: put values directly after `=` with nothing else on the line. Do not add
# inline `# comments` after a value — for empty keys some dotenv parsers read the
# comment as the value.

# --- LLM (required for a real run) ------------------------------------------
# Local default. Install the extra and pull the model before starting:
#   uv sync --extra ollama --all-groups
#   ollama pull qwen3:8b
SCOUT_MODEL=ollama:qwen3:8b
SCOUT_TAILOR_MODEL=ollama:qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_HEALTH_TIMEOUT=3
# Strict local mode. No live job APIs or cloud tracing are contacted.
OFFLINE_MODE=true
# Optional; required only when SCOUT_MODEL uses OpenAI:
OPENAI_API_KEY=
# Optional; only if SCOUT_MODEL uses groq:
GROQ_API_KEY=

# --- Opik observability (recommended — this is the point of the project) -----
# From https://www.comet.com/ (free).
OPIK_API_KEY=
# Your Comet workspace name. Leave EMPTY to use your API key's default workspace.
OPIK_WORKSPACE=
# Optional (default: the-agent-that-got-me-rejected):
OPIK_PROJECT_NAME=the-agent-that-got-me-rejected
# Offline mode overrides this setting. Set OFFLINE_MODE=false to use Opik.
OPIK_ENABLED=false

# --- JSearch (optional — primary live source, best city-level location) ------
# Official Google-for-Jobs aggregator (OpenWeb Ninja). Free tier ~200 req/month,
# so it's used for the live app; the batch/offline path stays on Adzuna + cache.
JSEARCH_API_KEY=

# --- Adzuna jobs API (optional — free international source) -------------------
# Free registration: https://developer.adzuna.com/ . Without any key above, the
# app uses Remotive (keyless) and the committed cache in data/cached_jobs.json.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- Guardrails --------------------------------------------------------------
# Optional circuit breaker (default: 25):
MAX_LLM_CALLS_PER_RUN=25
