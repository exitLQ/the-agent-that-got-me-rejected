# Job Scout — environment configuration.
# Copy to `.env` and fill in. The app runs with NO keys at all (Remotive +
# cached dataset), but you get the full lesson (real cost, live jobs, tracing)
# with the three services below.
#
# NOTE: put values directly after `=` with nothing else on the line. Do not add
# inline `# comments` after a value — for empty keys some dotenv parsers read the
# comment as the value.

# --- LLM (required for a real run) ------------------------------------------
# Default model. gpt-4o-mini / gpt-4.1-mini report real cost in Opik.
# Free alternatives (cost shows as $0.00 in Opik):
#   groq:llama-3.3-70b-versatile   (needs GROQ_API_KEY, `uv sync --extra groq`)
#   ollama:llama3.2                 (local, needs Ollama running)
SCOUT_MODEL=openai:gpt-4o-mini
# Optional (Phase 2). Defaults to the same as SCOUT_MODEL.
SCOUT_TAILOR_MODEL=openai:gpt-4o-mini
# Required for the default model:
OPENAI_API_KEY=
# Optional; only if SCOUT_MODEL uses groq:
GROQ_API_KEY=

# --- Opik observability (recommended — this is the point of the project) -----
# From https://www.comet.com/ (free).
OPIK_API_KEY=
# Your Comet workspace name. Leave EMPTY to use your API key's default workspace.
OPIK_WORKSPACE=
# Optional (default: job-scout):
OPIK_PROJECT_NAME=job-scout
# Set to false to disable all tracing:
OPIK_ENABLED=true

# --- Adzuna jobs API (optional — primary live source) ------------------------
# Free registration: https://developer.adzuna.com/ . Without these, the app
# uses Remotive (keyless) and the committed cache in data/cached_jobs.json.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- Guardrails --------------------------------------------------------------
# Optional circuit breaker (default: 25):
MAX_LLM_CALLS_PER_RUN=25
