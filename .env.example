# Job Scout — environment configuration.
# Copy to `.env` and fill in. The app runs with NO keys at all (Remotive +
# cached dataset), but you get the full lesson (real cost, live jobs, tracing)
# with the three services below.

# --- LLM (required for a real run; falls back to nothing without it) ---------
# Default model. gpt-4o-mini is chosen so Opik reports real per-run cost.
# Free alternatives (cost shows as $0.00 in Opik):
#   SCOUT_MODEL=groq:llama-3.3-70b-versatile   (needs GROQ_API_KEY, `uv sync --extra groq`)
#   SCOUT_MODEL=ollama:llama3.2                 (local, needs Ollama running)
SCOUT_MODEL=openai:gpt-4o-mini
SCOUT_TAILOR_MODEL=openai:gpt-4o-mini          # optional (Phase 2); default: same as SCOUT_MODEL
OPENAI_API_KEY=                                # required for the default model
# GROQ_API_KEY=                                # optional; only if SCOUT_MODEL uses groq

# --- Opik observability (recommended — this is the point of the project) -----
OPIK_API_KEY=                                  # from https://www.comet.com/ (free)
OPIK_WORKSPACE=                                # your Comet workspace name
OPIK_PROJECT_NAME=job-scout                    # optional (default: job-scout)
OPIK_ENABLED=true                              # set false to disable all tracing

# --- Adzuna jobs API (optional — primary live source) ------------------------
# Free registration: https://developer.adzuna.com/ . Without these, the app
# uses Remotive (keyless) and the committed cache in data/cached_jobs.json.
ADZUNA_APP_ID=                                 # optional
ADZUNA_APP_KEY=                                # optional

# --- Guardrails --------------------------------------------------------------
MAX_LLM_CALLS_PER_RUN=25                        # optional circuit breaker (default: 25)
